# ===== Flask =====
SECRET_KEY=change-me-in-prod
FLASK_DEBUG=0

# Generate with: docker compose run --rm backend python -m utils.security
FERNET_KEY=

# ===== Database =====
DATABASE_URL=postgresql+psycopg2://poddoctor:poddoctor@postgres:5432/poddoctor

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== AI =====
GROQ_MODEL=llama-3.1-70b-versatile
# Optional fallback when user has no per-account key
# GROQ_API_KEY=

# ===== Prometheus =====
PROMETHEUS_URL=http://prometheus:9090

# ===== Safety =====
REMEDIATION_DRY_RUN=0
