# PodDoctor configuration
# Set DEMO_MODE=true to use simulated cluster data (no kubeconfig needed)
DEMO_MODE=true

# Path to kubeconfig (used when DEMO_MODE=false). Leave empty to use in-cluster config.
KUBECONFIG=

# Optional: OpenAI-compatible LLM for richer AI diagnosis
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
